agent_id: dc1-agent-01
site_name: dc1

log_level: info
log_format: text

# An agent can subscribe to one or more logical channels.
# Use ["*"] only if the site should consume every channel assigned to it.
channels:
  - team-a

version: "v1"

# Relay and Harbor can share the same external port as long as they use
# different hostnames. Example:
# - registry.example.com:9443 -> Harbor
# - relay.example.com:9443    -> Harbor Relay
relay_address: relay.example.com:9443
relay_server_name: relay.example.com
insecure_skip_verify: false

source_registry: registry.example.com:9443
source_username: robot$team-a+source-sync
source_password: replace-with-source-credential

target_registry: registry-dr.example.com:9443
target_username: robot$team-a-dr+target-sync
target_password: replace-with-target-credential

docker_binary: docker
docker_config_dir: /var/lib/harbor-relay-agent/docker-config

heartbeat_interval: 10s
reconnect_interval: 5s
max_session_age: 30m

cleanup_local_images: true
