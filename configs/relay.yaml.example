service_name: harbor-relay

log_level: info
log_format: text

# Listen on all interfaces so Harbor can reach the webhook endpoint.
http_listen: 0.0.0.0:18080

# Keep gRPC private when you front it with Caddy or another reverse proxy.
grpc_listen: 127.0.0.1:19090

data_file: /var/lib/harbor-relay/relay-state.json

# Default source registry for webhook entries that do not override it explicitly.
source_registry: registry.example.com:9443

webhooks:
  - name: team-a
    enabled: true
    path: /api/v1/harbor/webhook/team-a
    authorization: "Bearer replace-with-a-random-shared-secret"
    source_registry: registry.example.com:9443

routes:
  - name: team-a-apps
    channel: team-a
    enabled: true
    webhook_names:
      - team-a
    repository_patterns:
      - "team-a/**"
    target_sites:
      - dc1

targets:
  - name: dc1
    site_name: dc1
    enabled: true
    target_registry: registry-dr.example.com:9443

    # If you need to rewrite the source project name on the target side,
    # set target_project. Example:
    #   source repository: team-a/backend
    #   target_project: team-a-dr
    #   final target repo: team-a-dr/backend
    target_project: team-a-dr

    # If you only need to prepend a path segment, use repository_prefix instead.
    repository_prefix: ""

    # Optional structured callback for an external operations platform.
    callback_enabled: false
    callback_url: "https://ops.example.com/api/image-sync/callback"
    callback_token: "replace-with-callback-token"

    notifications:
      - name: steward-queued
        type: onemsg_robot
        enabled: true
        endpoint: "https://office.example.com/onemsg-api/robot/pushToRobot"
        robot_key: "replace-with-queued-robot-key"
        title_prefix: "Steward Queued"
        events:
          - queued
        timeout: 10s
        min_interval: 1m
        retry_interval: 30s
        max_attempts: 0

      - name: steward-pulling
        type: onemsg_robot
        enabled: true
        endpoint: "https://office.example.com/onemsg-api/robot/pushToRobot"
        robot_key: "replace-with-pulling-robot-key"
        title_prefix: "Steward Pulling"
        events:
          - pulling
        timeout: 10s
        min_interval: 1m
        retry_interval: 30s
        max_attempts: 0

      - name: steward-pushing
        type: onemsg_robot
        enabled: true
        endpoint: "https://office.example.com/onemsg-api/robot/pushToRobot"
        robot_key: "replace-with-pushing-robot-key"
        title_prefix: "Steward Pushing"
        events:
          - pushing
        timeout: 10s
        min_interval: 1m
        retry_interval: 30s
        max_attempts: 0

      - name: steward-done
        type: onemsg_robot
        enabled: true
        endpoint: "https://office.example.com/onemsg-api/robot/pushToRobot"
        robot_key: "replace-with-done-robot-key"
        title_prefix: "Steward Done"
        events:
          - done
        timeout: 10s
        min_interval: 1m
        retry_interval: 30s
        max_attempts: 0

      - name: steward-failed
        type: onemsg_robot
        enabled: true
        endpoint: "https://office.example.com/onemsg-api/robot/pushToRobot"
        robot_key: "replace-with-failed-robot-key"
        title_prefix: "Steward Failed"
        events:
          - failed
          - callback_failed
        timeout: 10s
        min_interval: 1m
        retry_interval: 30s
        max_attempts: 0
