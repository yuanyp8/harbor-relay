[Unit]
Description=Harbor Relay Agent
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/local/bin/harbor-relay-agent --config /etc/harbor-relay/agent.yaml
WorkingDirectory=/data/harbor-relay-agent
Restart=always
RestartSec=5
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
